generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String              @id @default(uuid())
  email             String?             @unique
  name              String?
  number            String              @unique
  password          String
  Balance           Balance[]
  onRampTransaction OnRampTransaction[]
}

model Merchent {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  auth_type AuthType
}

model Balance {
  id     Int    @id @default(autoincrement())
  userId String @unique
  amount Int
  locked Int
  user   User   @relation(fields: [userId], references: [id])
}

model OnRampTransaction {
  id        Int              @id @default(autoincrement())
  status    OnRampStatusType
  token     String           @unique
  provider  String
  amount    Int
  startTime DateTime
  userId    String
  user      User             @relation(fields: [userId], references: [id])
}

enum AuthType {
  Google
  Github
}

enum OnRampStatusType {
  Success
  Failed
  Processing
}
